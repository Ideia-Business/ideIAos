#!/usr/bin/env bash
# adapter.sh.tmpl — Template para novos harness adapters
# Copie para adapters/<harness-name>/adapter.sh e implemente as funções.
# Uso: bash adapters/<harness>/adapter.sh [--dry-run] [--project-dir PATH]
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# ============================================================
# CONFIGURAÇÃO OBRIGATÓRIA — edite estas 3 variáveis
# ============================================================
HARNESS_NAME="__HARNESS_NAME__"   # ex: codex, gemini, zed, opencode
RULES_FORMAT="__RULES_FORMAT__"   # ex: mdc, md, json, txt
DESTINATION="__DESTINATION__"     # ex: $HOME/.codex/rules, $PROJECT_DIR/.zed
# ============================================================

IDEIAOS_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
SOURCE_DIR="$IDEIAOS_DIR/source"

DRY_RUN=false
PROJECT_DIR="${PWD}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

run() {
  if $DRY_RUN; then echo "[DRY] $*"; else "$@"; fi
}


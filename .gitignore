.env
.env.local
node_modules/
.aiox/

# Sistema
.DS_Store

# Artefatos gerados quando setup.sh é rodado dentro do próprio repo
# (o dev-setup não é um "projeto IdeiaOS" — é o provedor dos templates)
# Patterns ancorados em / pra só ignorar na raiz, não em subdiretórios.
/.aiox-ai-config.yaml
/IDEIAOS.md
/CONTRIBUTING.md
/docs/ideiaos/
# docs/learnings/: versionamos os aprendizados datados (trilha compartilhada no git),
# mas ignoramos o scaffolding gerado dos templates (README/_TEMPLATE rendered).
/docs/learnings/README.md
/docs/learnings/_TEMPLATE.md
/.cursor/rules/agents-md-protocol.mdc
/.cursor/rules/planning-branch.mdc
# Ponte Cursor de memória (v5): regenerada por máquina a cada import, nunca
# commitada — alwaysApply:true, conteúdo da memória shared inline (local-only).
/.cursor/rules/memory-bridge.mdc
# Staging local de memória que possa aflorar numa working tree normal (o store
# canônico vive em planning:.planning/memory/shared/ — NÃO ignorar esse). Aqui
# só barramos resíduos locais e o leak histórico (.lovable_mem_tmp.md).
/.planning/memory/local/
.lovable_mem_tmp.md

# plugins/ é gerado por scripts/build-plugins.sh (versionado para /plugin marketplace add)
# Apenas ignorar lixo de filesystem — o conteúdo gerado é commitado
plugins/**/.DS_Store
.aiox-core/
.antigravity/
.codex/
.gemini/
.kimi/
.cursor/rules/agents/
.github/agents/

# Environment & Secrets (AIOX)
.env.*.local
*.key
*.pem

# Dependencies (AIOX)
node_modules

# Build & Logs (AIOX)
dist/
build/
*.log
logs/
# EXCEÇÃO: o ledger de SOAK (.planning/soak/*.log) DEVE ser commitado — é o
# registro cross-máquina do gate (check-soak.sh). Sem isto, os heartbeats de
# máquinas diferentes nunca convergem e o SOAK nunca passa (bug latente do v11 W3).
!.planning/soak/
!.planning/soak/*.log
# EXCEÇÃO: o ledger do Selo de Frescor de Segurança (.security/review-ledger.log)
# DEVE ser commitado — é a prova cross-máquina do gate (check-security-freshness.sh).
# Mesmo padrão do SOAK; sem isto o *.log da linha 53 engole o ledger silenciosamente
# (learning broad-gitignore-sweeps-tracked-ledger). O .security/policy.sh (tunagem
# por repo, opcional) fica fora do git por convenção — não é commitado.
!.security/review-ledger.log
.security/policy.sh

# IDE & OS (AIOX)
Thumbs.db
.idea/
*.swp

# AIOX Local (AIOX)
.aiox-core/local/
.claude/settings.local.json
.aiox/install-log.txt

# AI-security intel (v12): o snapshot e os reports são cópia VERBATIM do README de
# terceiro (muellerberndt/awesome-ai-security = SEM LICENÇA / all-rights-reserved).
# NÃO redistribuímos a prosa → baseline LOCAL por máquina. Só o script/spec/plist
# (nossos) são versionados. Cada máquina mantém seu próprio snapshot p/ diff mensal.
security/intel/
